# BJS PMS — environment variables
# Copy to .env.sky-island or .env.membene and fill in values
# PROPERTY_ID is set via Coolify env var (1=Sky Island, 2=Membene)

PORT=3101
DATABASE_PATH=/opt/bjs-hospitality/database/hospitality.db
UPLOADS_PATH=/opt/bjs-hospitality/uploads
SESSION_SECRET=change-me-to-a-random-64-char-hex-string
APP_URL=http://localhost:3101

# Email (Brevo SMTP relay)
SMTP_HOST=smtp-relay.brevo.com
SMTP_PORT=587
SMTP_USER=your-brevo-smtp-login
SMTP_PASS=your-brevo-smtp-password
FROM_EMAIL=bookings@sunsafaridestinations.co.za
FROM_NAME=Sun Safari Destinations

# BJS OTA — environment variables
# Copy to .env and fill in values for local development
# In production, set these via Coolify environment variables

PORT=3100
DATABASE_PATH=/opt/bjs-hospitality/database/hospitality.db
UPLOADS_PATH=/opt/bjs-hospitality/uploads
SESSION_SECRET=change-me-to-a-random-64-char-hex-string
APP_URL=http://localhost:3100
